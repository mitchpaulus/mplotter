<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="csvplot.IemDialog"
        Title="Iowa Environmental Mesonet (IEM) Station Selection">

        <Grid RowDefinitions="Auto 1*">
                <Grid Grid.Row="0" RowDefinitions="auto auto" ColumnDefinitions="auto auto">
                        <TextBlock Grid.Row="0" Grid.Column="0">STID</TextBlock>
                        <TextBlock Grid.Row="1" Grid.Column="0">Station Name</TextBlock>

                        <TextBox Grid.Row="0" Grid.Column="1" Width="150" TextChanged="StidSearchChanged"></TextBox>
                        <TextBox Grid.Row="1" Grid.Column="1" Width="150" TextChanged="NameSearchChanged"></TextBox>
                </Grid>

                <ListBox Grid.Row="1" Name="IemStationsListBox" DoubleTapped="IemStationsListBox_OnDoubleTapped"></ListBox>
        </Grid>
</Window>
