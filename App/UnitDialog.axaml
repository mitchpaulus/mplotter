<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="csvplot.UnitDialog"
        Title="Unit">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition Height="*"></RowDefinition>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0">Choose a unit:</TextBlock>
        <TextBox Grid.Row="1"
                 x:Name="UnitSearchTextBox"
                 Margin="0,8,0,8"
                 Watermark="Search units..."
                 TextChanged="UnitSearchTextBox_OnTextChanged" />
        <TextBlock Grid.Row="2"
                   x:Name="NoteTextBlock"
                   Margin="0,0,0,8"
                   IsVisible="False"
                   TextWrapping="Wrap" />
        <ListBox Grid.Row="3" x:Name="UnitListBox" SelectionChanged="UnitListBox_OnSelectionChanged" />
    </Grid>
</Window>
