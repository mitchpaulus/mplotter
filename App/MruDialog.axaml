<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="720" d:DesignHeight="640"
        x:Class="csvplot.MruDialog"
        Title="Most Recently Used Files"
        Width="720"
        Height="640">

    <Grid RowDefinitions="Auto * Auto Auto" Margin="16">
        <TextBlock Text="Choose a recent source to reopen or remove."
                   Margin="0,0,0,10" />

        <ListBox Grid.Row="1"
                 Name="MruListBox"
                 DoubleTapped="MruListBox_OnDoubleTapped"
                 SelectionChanged="MruListBox_OnSelectionChanged" />

        <TextBlock Grid.Row="2"
                   Name="SelectedPathTextBlock"
                   Margin="0,10,0,0"
                   TextWrapping="Wrap" />

        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Spacing="8"
                    Margin="0,16,0,0">
            <Button Name="OpenButton"
                    IsEnabled="False"
                    Click="OpenButton_OnClick">Open</Button>
            <Button Name="RemoveButton"
                    IsEnabled="False"
                    Click="RemoveButton_OnClick">Remove</Button>
            <Button Click="CloseButton_OnClick">Close</Button>
        </StackPanel>
    </Grid>
</Window>
